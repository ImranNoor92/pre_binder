# Generated pipeline outputs and logs (regenerable; can be large — AF2 predictions etc.)
outputs/**
!outputs/.gitkeep
logs/**
!logs/.gitkeep

# Python / tooling cruft
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store

# Scratch
*.tmp
*.swp

# local notes / chat dumps (not part of the pipeline)
context/

# vendored external tools (clone via scripts/setup_af2ig.sh; not committed)
external/
